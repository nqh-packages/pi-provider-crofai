{
  "name": "pi-provider-crofai",
  "version": "0.1.1",
  "type": "module",
  "description": "CrofAI model provider extension for the pi coding agent.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "provider",
    "crofai",
    "openai-compatible",
    "llm"
  ],
  "license": "MIT",
  "author": "Huy Ngo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nqh-packages/pi-provider-crofai.git"
  },
  "homepage": "https://github.com/nqh-packages/pi-provider-crofai#readme",
  "bugs": {
    "url": "https://github.com/nqh-packages/pi-provider-crofai/issues"
  },
  "files": [
    "extensions/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./extensions/index.ts"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "build": "echo 'nothing to build'",
    "check": "pi --no-extensions -e . --list-models crofai >/dev/null",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  }
}
